<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="mx.edu.buap.servicetracker.controller.ReporteDialogController"
      spacing="10"
      prefWidth="500"
      prefHeight="400"
      style="-fx-padding: 20;">

    <Label text="Generar Reporte Técnico"
           style="-fx-font-size:18px; -fx-font-weight:bold;"/>

    <Label text="Diagnóstico"/>

    <TextArea fx:id="txtDiagnostico"
              prefHeight="120"
              wrapText="true"/>

    <Label text="Comentarios finales"/>

    <TextArea fx:id="txtComentariosFinales"
              prefHeight="120"
              wrapText="true"/>

    <HBox spacing="10">

        <Button text="Generar PDF"
                onAction="#generar"/>

        <Button text="Cancelar"
                onAction="#cancelar"/>

    </HBox>

</VBox>
