<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="mx.edu.buap.servicetracker.controller.GestionController">

    <top>
        <VBox spacing="10">
            <Button text="← Regresar"
                    onAction="#volverRegistro"/>

            <Label text="Gestión de Servicios"
                   style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
        </VBox>
    </top>


    <center>
        <VBox spacing="10" style="-fx-padding: 10;">
            <HBox spacing="10">
                <Label text="Propietario"/>
                <TextField fx:id="txtBuscarPropietario" prefWidth="150"/>

                <Label text="Técnico"/>
                <ComboBox fx:id="cbFiltroTecnico" prefWidth="140"/>

                <Label text="Estado"/>
                <ComboBox fx:id="cbFiltroEstado" prefWidth="160"/>

                <Label text="Prioridad"/>
                <ComboBox fx:id="cbFiltroPrioridad" prefWidth="120"/>

                <Button text="Buscar" onAction="#buscarServicios"/>
                <Button text="Limpiar" onAction="#limpiarFiltros"/>
            </HBox>

            <TableView fx:id="tablaServicios" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colFolio" text="Folio"/>
                    <TableColumn fx:id="colPropietario" text="Propietario"/>
                    <TableColumn fx:id="colEquipo" text="Equipo"/>
                    <TableColumn fx:id="colEstado" text="Estado"/>
                    <TableColumn fx:id="colTecnico" text="Técnico"/>
                </columns>
            </TableView>
        </VBox>
    </center>

    <bottom>
        <HBox spacing="30">
            <VBox spacing="8">
                <Separator/>

                <Label text="Detalle del Servicio"
                       style="-fx-font-size:18px; -fx-font-weight:bold;"/>

                <Label fx:id="lblPropietario"
                       text="Propietario:"/>

                <Label fx:id="lblArea"
                       text="Área:"/>

                <Label fx:id="lblMarca"
                       text="Marca:"/>

                <Label fx:id="lblModelo"
                       text="Modelo:"/>

                <Label fx:id="lblSerie"
                       text="Serie:"/>

                <Label fx:id="lblTipo"
                       text="Tipo:"/>

                <Label text="Comentarios:"/>

                <TextArea fx:id="txtComentarios"
                          editable="false"
                          prefHeight="100"/>
            </VBox>

            <VBox spacing="10">
                <Label text="Asignación"
                       style="-fx-font-size:18px; -fx-font-weight:bold;"/>

                <Label text="Técnico"/>

                <ComboBox fx:id="cbTecnico"/>

                <Label text="Fecha de asignación"/>

                <DatePicker fx:id="dpFechaAsignacion"/>

                <Label text="Fecha estimada de entrega"/>

                <DatePicker fx:id="dpFechaEstimada"/>

                <Button text="Actualizar asignación"
                        onAction="#actualizarAsignacion"/>

                <Separator/>

                <Label text="Estado del servicio"/>
                <ComboBox fx:id="cbEstado"/>
                <Button text="Actualizar estado" onAction="#actualizarEstado"/>

                <Label text="Eliminar servicio"/>
                <Button text="Eliminar Servicio" onAction="#eliminarServicio"/>
            </VBox>

            <Separator/>

            <Label text="Actividades"
                   style="-fx-font-size:16px; -fx-font-weight:bold;"/>

            <TextArea fx:id="txtActividad"
                      prefHeight="70"/>

            <Button text="Agregar actividad"
                    onAction="#agregarActividad"/>

            <TableView fx:id="tablaActividades"
                       prefHeight="180">

                <columns>

                    <TableColumn fx:id="colFechaActividad"
                                 text="Fecha"/>

                    <TableColumn fx:id="colDescripcionActividad"
                                 text="Actividad"/>

                    <TableColumn fx:id="colTecnicoActividad"
                                 text="Técnico"/>

                </columns>

            </TableView>

            <Button text="Generar Reporte PDF" onAction="#abrirDialogReporte"/>
        </HBox>
    </bottom>

</BorderPane>