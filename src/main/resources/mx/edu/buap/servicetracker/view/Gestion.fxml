<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml" style="-fx-background-color: #F8FAFC;" stylesheets="@css/gestion.css" fx:controller="mx.edu.buap.servicetracker.controller.GestionController">

    <top>
        <VBox spacing="10" styleClass="header-section">
            <padding><Insets top="20" right="40" bottom="20" left="40"/></padding>
            <Label text="Gestión de servicios" styleClass="header-title"/>
            <Label text="Consulta, asigna técnicos, actualiza estados y registra actividades." styleClass="page-subtitle"/>
        </VBox>
    </top>

    <center>
        <SplitPane orientation="VERTICAL" dividerPositions="0.5" style="-fx-background-color: transparent;">
            <VBox spacing="20" styleClass="content-container">
                <padding><Insets top="0" right="40" bottom="20" left="40"/></padding>
                <HBox spacing="15" alignment="CENTER_LEFT" styleClass="filter-card">
                    <VBox>
                        <Label text="Filtros de búsqueda" styleClass="card-title"/>
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <VBox spacing="8" HBox.hgrow="ALWAYS">
                                    <Label text="Propietario" styleClass="field-label"/>
                                    <TextField fx:id="txtBuscarPropietario" promptText="Propietario" styleClass="form-control"/>
                                </VBox>
                                <VBox spacing="8" HBox.hgrow="ALWAYS">
                                    <Label text="Técnico" styleClass="field-label"/>
                                    <ComboBox fx:id="cbFiltroTecnico" promptText="Técnico" styleClass="form-control"/>
                                </VBox>
                                <VBox spacing="8" HBox.hgrow="ALWAYS">
                                    <Label text="Estado" styleClass="field-label"/>
                                    <ComboBox fx:id="cbFiltroEstado" promptText="Estado" styleClass="form-control"/>
                                </VBox>
                                <VBox spacing="8" HBox.hgrow="ALWAYS">
                                    <Label text="Prioridad" styleClass="field-label"/>
                                    <ComboBox fx:id="cbFiltroPrioridad" promptText="Prioridad" styleClass="form-control"/>
                                </VBox>
                                <Button text="Buscar" styleClass="btn-primary" onAction="#buscarServicios"/>
                                <Button text="Limpiar" styleClass="btn-secondary" onAction="#limpiarFiltros"/>
                            </HBox>

                        <HBox>
                            <TableView fx:id="tablaServicios" VBox.vgrow="ALWAYS" styleClass="data-table">
                                <columns>
                                    <TableColumn fx:id="colFolio" text="Folio" prefWidth="80"/>
                                    <TableColumn fx:id="colPropietario" text="Propietario" prefWidth="150"/>
                                    <TableColumn fx:id="colTecnico" text="Técnico" prefWidth="150"/>
                                    <TableColumn fx:id="colEquipo" text="Equipo" prefWidth="150"/>
                                    <TableColumn fx:id="colEstado" text="Estado" prefWidth="120"/>
                                    <TableColumn fx:id="colPrioridad" text="Prioridad" prefWidth="100"/>
                                </columns>
                            </TableView>
                        </HBox>
                    </VBox>
                </HBox>
            </VBox>

            <HBox spacing="20" styleClass="bottom-container">
                <padding><Insets bottom="30" left="40" right="40"/></padding>

                <HBox spacing="20" styleClass="form-card" HBox.hgrow="ALWAYS">
                    <VBox spacing="8">
                        <Label text="Detalle del Servicio" style="-fx-font-size:18px; -fx-font-weight:bold;"/>
                        <Separator/>
                        <Label fx:id="lblPropietario" text="Propietario: "/>
                        <Label fx:id="lblArea" text="Área: "/>
                        <Label fx:id="lblMarca" text="Marca: "/>
                        <Label fx:id="lblModelo" text="Modelo: "/>
                        <Label fx:id="lblSerie" text="Serie: "/>
                        <Label fx:id="lblTipo" text="Tipo: "/>
                        <Label text="Comentarios:"/>
                        <TextArea fx:id="txtComentarios" editable="false" prefHeight="100" styleClass="form-control"/>

                        <Button text="Eliminar Servicio" onAction="#eliminarServicio" styleClass="btn-warning"/>

                        <Button text="Regresar A Registro" styleClass="btn-primary" onAction="#volverRegistro"/>
                    </VBox>

                    <VBox spacing="10">
                        <Label text="Asignación" style="-fx-font-size:18px; -fx-font-weight:bold;"/>
                        <Label text="Técnico responsable *"/>
                        <ComboBox fx:id="cbTecnico" maxWidth="1.79E308" styleClass="form-control"/>

                        <Label text="Fecha de asignación"/>
                        <DatePicker fx:id="dpFechaAsignacion" maxWidth="1.79E308" styleClass="form-control"/>

                        <Label text="Fecha estimada de entrega"/>
                        <DatePicker fx:id="dpFechaEstimada" maxWidth="1.79E308" styleClass="form-control"/>

                        <Button text="Actualizar asignación" onAction="#actualizarAsignacion" styleClass="btn-secondary" maxWidth="1.79E308"/>

                        <Label text="Estado del servicio *" style="-fx-font-size:18px; -fx-font-weight:bold;"/>
                        <ComboBox fx:id="cbEstado" maxWidth="1.79E308" styleClass="form-control"/>
                        <Button text="Actualizar estado" onAction="#actualizarEstado" styleClass="btn-secondary" maxWidth="1.79E308"/>
                    </VBox>
                </HBox>

                <VBox spacing="15" styleClass="form-card" HBox.hgrow="ALWAYS" prefWidth="400">
                    <Label text="Actividades realizadas" style="-fx-font-size:18px; -fx-font-weight:bold;"/>
                    <TextArea fx:id="txtActividad" promptText="Describe la actividad realizada..." prefHeight="70" styleClass="form-control"/>
                    <Button text="Agregar actividad" onAction="#agregarActividad" styleClass="btn-primary" maxWidth="1.79E308"/>

                    <TableView fx:id="tablaActividades" VBox.vgrow="ALWAYS" styleClass="data-table">
                        <columns>
                            <TableColumn fx:id="colFechaActividad" text="Fecha" prefWidth="100"/>
                            <TableColumn fx:id="colDescripcionActividad" text="Actividad" prefWidth="200"/>
                            <TableColumn fx:id="colTecnicoActividad" text="Técnico" prefWidth="100"/>
                        </columns>
                    </TableView>

                    <Button text="Quitar Actividad" onAction="#eliminarActividad" styleClass="btn-warning" maxWidth="1.79E308"/>
                    <Button text="Generar Reporte PDF" onAction="#abrirDialogReporte" styleClass="btn-secondary" maxWidth="1.79E308"/>
                </VBox>
            </HBox>
        </SplitPane>
    </center>
</BorderPane>